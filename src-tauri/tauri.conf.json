{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "work-log",
  "version": "0.2.0",
  "identifier": "dev.senri.work-log",
  "build": {
    "frontendDist": "../desktop"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "work-log",
        "width": 1440,
        "height": 960,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  }
}
